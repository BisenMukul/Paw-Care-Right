{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@pawcareright/types": ["../types/dist/index.d.ts"],
      "@pawcareright/api-client": ["../api-client/dist/index.d.ts"],
      "@pawcareright/api-client/mmkv-persister": ["../api-client/dist/mmkv-persister.d.ts"]
    }
  }
}
