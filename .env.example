# Paw Care Right + — example environment. Copy to .env and fill real values.
# .env is gitignored; this file is committed. List every key used across the repo here.

# --- AI providers (server-side only; never shipped in the client bundle). See docs/AI_PROVIDERS.md ---
GEMINI_API_KEY=example-gemini-api-key
GEMINI_IMAGE_MODEL=gemini-example-image-model
OLLAMA_CLOUD_API_KEY=example-ollama-cloud-api-key
OLLAMA_CLOUD_BASE_URL=https://ollama.com
AI_TEXT_MODEL=example-text-model
AI_VISION_MODEL=example-vision-model

# --- Local infrastructure (docker compose; dev-only fake creds) ---
POSTGRES_USER=pawcareright
POSTGRES_PASSWORD=pawcareright
POSTGRES_DB=pawcareright
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_ROOT_USER=pawcareright
MINIO_ROOT_PASSWORD=pawcareright-dev-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
DATABASE_URL=postgresql://pawcareright:pawcareright@localhost:5432/pawcareright?schema=public
REDIS_URL=redis://localhost:6379

# --- Auth (apps/api; email OTP + JWT + refresh rotation) ---
JWT_SECRET=dev-insecure-jwt-secret-do-not-use-in-production
OTP_HMAC_SECRET=dev-insecure-otp-hmac-secret-do-not-use-in-production
APPLE_CLIENT_ID=com.pawcareright.app
