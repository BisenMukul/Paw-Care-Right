{
  "name": "@pawcareright/api",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "jest",
    "test:cov": "jest --coverage",
    "load:sanity": "tsx test/load/checks-load-sanity.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/s3-request-presigner": "^3",
    "@nestjs/bullmq": "^11",
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/swagger": "^11",
    "@nestjs/throttler": "^6.5.0",
    "@pawcareright/ai": "workspace:*",
    "@pawcareright/config": "workspace:*",
    "@pawcareright/data": "workspace:*",
    "@pawcareright/types": "workspace:*",
    "@prisma/client": "^6",
    "bullmq": "^5",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "helmet": "^8.2.0",
    "ioredis": "^5",
    "jose": "^5",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "sharp": "^0.33",
    "zod": "^4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11",
    "@types/express": "^5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22",
    "@types/supertest": "^6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import-x": "^4.17.1",
    "jest": "^29.7.0",
    "prettier": "^3.9.5",
    "prisma": "^6",
    "supertest": "^7",
    "ts-jest": "^29.2.5",
    "tsx": "^4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/test"
    ],
    "setupFiles": [
      "<rootDir>/test/jest.setup.ts"
    ],
    "globalSetup": "<rootDir>/test/global-setup.ts",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/tsconfig.spec.json"
        }
      ]
    },
    "testMatch": [
      "**/*.spec.ts",
      "**/*.e2e-spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "moduleNameMapper": {
      "^@pawcareright/config$": "<rootDir>/../../packages/config/src/index.ts",
      "^@pawcareright/config/env$": "<rootDir>/../../packages/config/src/env/index.ts",
      "^@pawcareright/data$": "<rootDir>/../../packages/data/src/index.ts"
    },
    "collectCoverageFrom": [
      "src/**/*.service.ts"
    ],
    "coverageDirectory": "<rootDir>/coverage",
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "lines": 80,
        "functions": 80,
        "branches": 70
      }
    }
  }
}
