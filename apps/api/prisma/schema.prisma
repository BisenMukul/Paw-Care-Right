generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MEMBER
}

enum Species {
  DOG
  CAT
}

enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

enum CheckStatus {
  QUEUED
  RUNNING
  DONE
  FALLBACK
}

enum ReminderEventStatus {
  PENDING
  SENT
  DONE
  SNOOZED
  MISSED
}

enum HealthLogKind {
  WEIGHT
  MEAL
  NOTE
  VET_VISIT
  MED_GIVEN
  CHECK_REF
}

enum SubscriptionEntitlement {
  FREE
  PREMIUM
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  appleSub  String?  @unique
  googleSub String?  @unique
  locale    String
  region    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedHouseholds Household[]       @relation("HouseholdOwner")
  memberships     Membership[]
  devices         Device[]
  refreshTokens   RefreshToken[]
  createdInvites  HouseholdInvite[] @relation("InviteCreator")
  acceptedInvites HouseholdInvite[] @relation("InviteAcceptor")
  createdChecks   SymptomCheck[]
  notificationPrefs UserNotificationPrefs?
  subscription    Subscription?
}

model Household {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  owner     User     @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  pets          Pet[]
  invites       HouseholdInvite[]
  subscriptions Subscription[]

  @@index([ownerId])
}

model Membership {
  id          String    @id @default(uuid())
  userId      String
  householdId String
  role        Role      @default(MEMBER)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, householdId])
  @@index([userId])
  @@index([householdId])
}

model Device {
  id            String   @id @default(uuid())
  userId        String
  expoPushToken String   @unique
  platform      String
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Per-user notification preferences (T058): per-type on/off + an optional
// all-or-nothing quiet-hours window. A missing row means "all defaults"
// (every type on, no quiet window) — see plan decision 1 — so no backfill
// is needed for existing users; the service creates the row lazily via
// `upsert` on first `PUT`.
model UserNotificationPrefs {
  userId        String    @id
  disabledTypes String[]  @default([])
  quietStart    String?
  quietEnd      String?
  timezone      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  familyId  String    @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  rotatedAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model Pet {
  id                String         @id @default(uuid())
  householdId       String
  species           Species
  breedSlug         String?
  name              String
  sex               Sex            @default(UNKNOWN)
  neutered          Boolean        @default(false)
  birthDate         DateTime?
  ageEstimateMonths Int?
  weightGrams       Int?
  photoKey          String?
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  household         Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  checks            SymptomCheck[]
  reminders         Reminder[]
  healthLogs        HealthLog[]

  @@index([householdId, deletedAt])
}

model HouseholdInvite {
  id          String    @id @default(uuid())
  code        String    @unique
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  usedById    String?
  usedBy      User?     @relation("InviteAcceptor", fields: [usedById], references: [id], onDelete: SetNull)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([householdId])
  @@index([expiresAt])
}

model SymptomCheck {
  id                String      @id @default(uuid())
  petId             String
  createdById       String
  status            CheckStatus @default(QUEUED)
  category          String
  intakeJson        Json
  photoKeys         String[]    @default([])
  redFlagHit        Boolean     @default(false)
  redFlagRuleId     String?
  redFlagPayloadKey String?
  costMicroUsd      Int         @default(0)
  failureReason     String?
  idempotencyKey    String?
  createdAt         DateTime    @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  updatedAt         DateTime    @updatedAt

  pet       Pet             @relation(fields: [petId], references: [id], onDelete: Cascade)
  createdBy User            @relation(fields: [createdById], references: [id], onDelete: Restrict)
  result    TriageResult?
  followUp  CheckFollowUp?

  // idempotencyKey is nullable; Postgres treats NULLs as distinct for a
  // unique index, so multiple non-idempotent (NULL-key) checks per user are
  // unconstrained by design (plan R5 / index justification table).
  @@unique([createdById, idempotencyKey])
  @@index([petId, createdAt(sort: Desc)])
  @@index([createdById])
}

model TriageResult {
  checkId       String   @id
  urgency       String
  confidence    String
  resultJson    Json
  modelId       String
  promptVersion String
  createdAt     DateTime @default(now())

  check SymptomCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)
}

model CheckFollowUp {
  checkId       String   @id
  response      String // "better" | "same" | "worse" (validated by Zod at the boundary; String mirrors TriageResult.urgency)
  escalatedTier String? // an Urgency value, set ONLY when response == "worse"
  createdAt     DateTime @default(now())

  check SymptomCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)
}

model Reminder {
  id               String   @id @default(uuid())
  petId            String
  type             String // validated by reminderTypeSchema at the DTO boundary (String mirrors TriageResult.urgency)
  title            String
  rrule            String // RFC5545 subset, validated by @IsRRule at the DTO boundary
  timezone         String // IANA tz id (e.g. "Europe/Paris")
  startAt          DateTime // DTSTART anchor (UTC) — recurrence origin; nextFireAt/agenda computed from this
  nextFireAt       DateTime // UTC; set on create (first occurrence >= startAt), advanced by the T056 worker
  medNameAsEntered String? // T061 med subtype: name as entered; never suggested
  medDoseAsEntered String? // T061 med subtype: dose as entered; never suggested
  courseId         String? // T061: groups sibling dose-time reminders that make up one medication course (no dedicated index -- access is always pet-scoped, mirrors templateKey)
  active           Boolean  @default(true) // T058/T060 pause/disable
  templateKey      String? // T054/T055/T059 template-pack provenance + instantiation idempotency
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pet    Pet             @relation(fields: [petId], references: [id], onDelete: Cascade)
  events ReminderEvent[]

  @@index([petId])
  @@index([active, nextFireAt])
}

model ReminderEvent {
  id           String              @id @default(uuid())
  reminderId   String
  dueAt        DateTime // UTC
  status       ReminderEventStatus @default(PENDING)
  sentAt       DateTime? // set by T056/T057 on push, and by T060 refireSnoozed
  completedAt  DateTime? // set by T055/T060 complete endpoint / T061 MED_GIVEN
  snoozedUntil DateTime? // set by T060 snooze endpoint; cleared on complete/refire
  createdAt    DateTime            @default(now())

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@unique([reminderId, dueAt])
  @@index([dueAt, status])
  @@index([reminderId])
  @@index([status, snoozedUntil])
  // T064: powers the MED_GIVEN read-time projection query (DONE events,
  // newest completedAt first, for a reminder). Additive index only -- no
  // column/behavior change to this T060-owned model (plan §4 / risk R6).
  @@index([reminderId, status, completedAt(sort: Desc)])
}

// HealthLog (T063): a pet's health timeline entry. `kind` selects which
// `packages/types` `valueJson` shape applies (validated at write & read by
// `parseHealthLogValue`, single source of truth). Backlinks for CHECK_REF
// (-> SymptomCheck) and MED_GIVEN (-> ReminderEvent) live INSIDE valueJson,
// not as dedicated FK columns -- ARCHITECTURE §3's authoritative field list
// is exactly (id, petId, kind, valueJson, photoKeys[], occurredAt) (plan
// decision 2 / risk R1). `photoKeys` reuses the existing T023 upload
// pipeline's keys -- no new upload code here.
model HealthLog {
  id          String        @id @default(uuid())
  petId       String
  kind        HealthLogKind
  valueJson   Json
  photoKeys   String[]      @default([])
  occurredAt  DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, occurredAt(sort: Desc)])
  // T064: powers the single-kind filtered timeline list page.
  @@index([petId, kind, occurredAt(sort: Desc)])
}

// Subscription (T072): a RevenueCat-mirror row, one per purchaser
// (`rcAppUserId` == backend `User.id` -- T071 set purchaser identity via
// `Purchases.logIn(user.id)`). Field list is exactly ARCHITECTURE §3
// (plan decision 1/2); cardinality is per-purchaser (not per-household, as
// the ERD's `||--o|` implies) per the plan's documented, card-authorized
// conflict resolution -- ARCHITECTURE line 3 says follow the task card.
// "Family" plans are detected via `FAMILY_PLAN_PRODUCT_ID` (packages/types),
// not a stored column. T073 owns writes (RC webhook upsert by
// `rcAppUserId`); this model is read-only from this task's perspective.
model Subscription {
  rcAppUserId  String                  @id
  householdId  String
  entitlement  SubscriptionEntitlement @default(FREE)
  plan         String?
  status       String
  expiresAt    DateTime?
  lastEventAt  DateTime?
  rawEventJson Json
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  user      User      @relation(fields: [rcAppUserId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

model ProcessedWebhookEvent {
  eventId     String   @id
  processedAt DateTime @default(now())
}
