{
  "extends": "@pawcareright/config/tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@pawcareright/ai": ["../ai/dist/index.d.ts"],
      "@pawcareright/analytics": ["../analytics/dist/index.d.ts"],
      "@pawcareright/types": ["../types/dist/index.d.ts"],
      "@pawcareright/data": ["../data/dist/index.d.ts"],
      "@pawcareright/config": ["../config/src/index.ts"],
      "@pawcareright/config/env": ["../config/src/env/index.ts"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["**/*.spec.ts", "**/*.e2e-spec.ts"]
}
